FROM ghcr.io/astral-sh/uv:0.11.21 AS uv

FROM registry.access.redhat.com/ubi8/ubi:8.10

COPY --from=uv /uv /uvx /usr/local/bin/

RUN dnf install -y \
        binutils \
        file \
        libatomic \
        python3.11 \
    && dnf clean all \
    && rm -rf /var/cache/dnf

ENV PYTHONUNBUFFERED=1 \
    UV_NO_MANAGED_PYTHON=1 \
    UV_PYTHON_DOWNLOADS=never

WORKDIR /workspace
